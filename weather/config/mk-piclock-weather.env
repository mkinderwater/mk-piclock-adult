# The GUI-managed source file is authoritative.
MK_WEATHER_SOURCE_CONFIG=/var/lib/mk-piclock-weather/weather-source.url
MK_WEATHER_FRAME_CONFIG=/var/lib/mk-piclock-weather/weather-frames.conf

# Normalized diagnostic/cache output.
MK_WEATHER_OUTPUT=/run/mk-piclock/weather.json
MK_WEATHER_CACHE=/var/lib/mk-piclock-weather/weather-last-good.json
MK_WEATHER_STATUS=/var/lib/mk-piclock-weather/status.json
MK_WEATHER_ACTIVITY=/var/lib/mk-piclock-weather/activity.json

# OLED-native pixel-art sprite library selected by official ECCC icon code.
MK_WEATHER_ICON_LIBRARY=/usr/local/share/mk-piclock-weather/icons
MK_WEATHER_ICON_RUNTIME=/run/mk-piclock/weather-icons

# Existing mk-piclock weather update route.
MK_WEATHER_API_URL=http://127.0.0.1:8080/api/v1/weather
MK_WEATHER_API_TIMEOUT=5
MK_WEATHER_TIMEZONE=America/Edmonton

MK_WEATHER_TIMEOUT=10
MK_WEATHER_FORECAST_PERIODS=6
MK_WEATHER_HOURLY_PERIODS=48

# 90 minutes and 6 hours.
MK_WEATHER_STALE_AFTER=5400
MK_WEATHER_EXPIRE_AFTER=21600

MK_WEATHER_USER_AGENT=mk-clock-adult-weather/2.0.14
